# Please do not remove this line
source /etc/bashrc.modules

# Load Nextflow dependencies
source /home/jchang99/.bashrc
conda activate nf-env

module load htslib/1.22.1

nextflow run unnamed/main.nf \
  --reads "hmibioinfo/*_{R1,R2}_001.fastq.gz" \
  -resume \
  -profile stjude
